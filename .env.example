# =======================
# APPLICATION
# =======================
NODE_ENV=development

# =======================
# DATABASE (PostgreSQL)
# =======================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hination
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_32chars
POSTGRES_DB=hination

# =======================
# REDIS
# =======================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password_32chars

# =======================
# RABBITMQ
# =======================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# =======================
# JWT AUTHENTICATION
# =======================
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_jwt_access_secret_64_chars_random_here_minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_64_chars_random_here
JWT_REFRESH_EXPIRY=7d

# =======================
# STATIC API TOKEN (Scoring System)
# =======================
# IMPORTANT: Generate with: openssl rand -hex 64
# This token is for machine-to-machine authentication (grading system)
# It does NOT expire - rotate manually when needed
STATIC_API_TOKEN=CHANGE_ME_static_api_token_64_chars_minimum_random_here_for_scoring_system

# =======================
# ADMIN ACCOUNT (Initial Setup)
# =======================
ADMIN_USERNAME=admin
# Generate bcrypt hash with: node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your_password', 12).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=CHANGE_ME_bcrypt_hash_of_admin_password

# =======================
# AI SERVER (Self-hosted)
# =======================
# Will be configured later
AI_API_URL=http://localhost:8000/api/grade
AI_API_KEY=CHANGE_ME_ai_api_key

# =======================
# FRONTEND
# =======================
NEXT_PUBLIC_API_URL=http://localhost:8080/api
